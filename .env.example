# ESMOS Docker Environment Variables
# Copy this file to .env on each VM and fill in real values.
# NEVER commit .env to git.

# ─── Odoo / PostgreSQL ────────────────────────────────────────────────────────
ODOO_DB_PASSWORD=change_me_odoo_db_password

# ─── Moodle / MariaDB ─────────────────────────────────────────────────────────
MARIADB_ROOT_PASSWORD=change_me_mariadb_root_password
MOODLE_DB_PASSWORD=change_me_moodle_db_password
# Moodle admin account is configured via the web installer on first run
